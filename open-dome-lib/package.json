{
  "name": "opendome",
  "version": "1.0.0",
  "description": "Enterprise SDK for Open-Dome module integration and secure handover.",
  "main": "dist/index.js",
  "module": "src/index.js",
  "scripts": {
    "build": "babel src --out-dir dist --extensions \".js,.jsx\"",
    "fix:noble": "node scripts/fix-noble.js",
    "prepare": "npm run fix:noble && npm run build",
    "postinstall": "npm run fix:noble"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.60.0"
  },
  "keywords": [
    "effisend",
    "opendome",
    "security",
    "handover",
    "enterprise"
  ],
  "author": "Effisend Labs",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "babel-plugin-module-resolver": "^5.0.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.9.0",
    "@solana/web3.js": "^1.98.4",
    "ethers": "^6.16.0",
    "mqtt": "^5.15.1",
    "starknet": "^10.0.2",
    "viem": "^2.48.11"
  }
}
